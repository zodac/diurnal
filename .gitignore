# Environment
.env

# Maven
target/

# Compiled Tailwind CSS — build artifact generated from frontend/css/app.css by `npm run css`
# (and the Maven `css-build` exec / the Docker css stage). The source is the committed one.
src/main/resources/META-INF/resources/css/app.css

# Vendored third-party browser libraries — build artifacts copied out of node_modules by
# `npm run vendor` (scripts/vendor-assets.cjs), run by the Maven `vendor-assets` exec / the Docker
# css stage. The source of truth is the exact-pinned devDependency in frontend/package.json.
src/main/resources/META-INF/resources/js/htmx.min.js

# In-app Settings preview thumbnails — build artifacts generated INSIDE the Docker build (the
# Dockerfile `screenshots` stage runs `scripts/generate-screenshots.cjs app`) and baked into the image.
# Deliberately NOT committed so the shipped image always has current previews; a dev / `mvn package` run
# simply has none. (The committed README shots live under docs/screenshots/.)
src/main/resources/META-INF/resources/img/settings/*.webp

# IDE
.idea/
*.iml
.vscode/

# OS
.DS_Store

# Playwright
node_modules/
tests/playwright-report/
tests/test-results/

# Perf suite (tests/run-perf.sh) seed->load handover scratch dir — normally removed by the script's
# own cleanup trap; ignored as a safety net if a run is killed before that trap fires.
tests/.perf-state.*

# Per-user Claude Code state (the checked-in .claude docs are CLAUDE.md, APIS.md, CODE_STYLE.md, UI_PATTERNS.md)
.claude/settings.local.json
.claude/scheduled_tasks.lock
