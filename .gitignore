# Environment
.env

# JWT keys — auto-generated on first start (see JwtKeyProvisioner)
secrets/
src/main/resources/jwt-keys/
# Root-level pair generated when the app runs with the base/prod profile from the repo root
# (application.properties defaults the key locations to the relative `jwt-keys/*.pem`).
/jwt-keys/

# Maven
target/

# Compiled Tailwind CSS — build artifact generated from src/main/css/app.css by `npm run css`
# (and the Maven `css-build` exec / the Docker css stage). The source is the committed one.
src/main/resources/META-INF/resources/css/app.css

# Vendored third-party browser libraries — build artifacts copied out of node_modules by
# `npm run vendor` (scripts/vendor-assets.cjs), run by the Maven `vendor-assets` exec / the Docker
# css stage. The source of truth is the exact-pinned devDependency in package.json.
src/main/resources/META-INF/resources/js/htmx.min.js


# IDE
.idea/
*.iml
.vscode/

# OS
.DS_Store

# Playwright
node_modules/
e2e/playwright-report/
e2e/test-results/
