# Copy to .env and fill in values before running docker compose

# Timezone — IANA timezone name used by both containers and the Java app
TZ=UTC

# Logging — INFO (default), DEBUG (login events + detailed traces) or TRACE (per-request logging).
# Controls the net.zodac.diurnal.* categories only.
LOG_LEVEL=INFO

# Database query tracing — separate from LOG_LEVEL. WARN (default, off) or TRACE to log every SQL
# statement + bound parameters the app sends to Postgres. Verbose; may expose parameter values.
DB_LOG_LEVEL=WARN

# Database
DB_NAME=diurnal_db
DB_USER=diurnal_user
DB_PASSWORD=change-me-strong-password

# Application port (host)
APP_PORT=8080

# Reverse proxy — trust X-Forwarded-* headers (needed for https:// OIDC redirect URIs and Secure
# cookies when a proxy like Traefik terminates TLS). ONLY enable behind a trusted proxy that
# sets/strips these headers; if the app is exposed directly, clients can spoof them. The bundled
# docker-compose.yml defaults this to true because it runs behind Traefik.
TRUST_X_FORWARDED_HEADERS=true

# --- Authentication ---------------------------------------------------------
# Two sign-in methods: password (local accounts) and OIDC (an identity provider). They can run
# separately or together; at least one must be enabled or the app refuses to start. The very FIRST
# account is always created locally via the setup page, whatever is configured below — it is the
# sysops break-glass administrator (and can change its password even with password login disabled).

# Password sign-in — set to false to disable password login (requires OIDC_ENABLED=true).
PASSWORD_AUTH_ENABLED=true
# Set to false to prevent new password accounts being created via the /register page.
# OIDC accounts are always provisioned automatically on first login regardless of this setting —
# except the very first account (see above).
ENABLE_REGISTRATION=true

# Sessions — server-side; opaque tokens in the `sessions` table (revocable). Lifetimes are ISO-8601.
# A session dies at whichever comes first: idle since last use, or absolute age since creation.
SESSION_IDLE_TIMEOUT=P30D
SESSION_ABSOLUTE_LIFETIME=P90D

# OIDC — set OIDC_ENABLED=true for IdP login (Authorization Code flow).
# Unauthenticated users always land on /login and can choose OIDC or password (if both enabled).
# Register {your-base-url}/ as the callback/redirect URI with your IdP.
OIDC_ENABLED=false
OIDC_ISSUER_URL=https://auth.example.com
OIDC_CLIENT_ID=diurnal
OIDC_CLIENT_SECRET=
# Name shown in the login button: "Log in with <OIDC_PROVIDER_NAME>"
OIDC_PROVIDER_NAME=Authelia
# If true, /login immediately redirects to the OIDC flow (skips the login page).
# Only applies when OIDC_ENABLED=true. Ignored when ?error or ?registered params are present.
OIDC_AUTO_REDIRECT=false
# Extra scopes requested alongside the automatic openid scope (comma-separated). The default asks
# for the non-standard groups scope (Authelia/Keycloak convention); providers that reject unknown
# scopes (e.g. Google) need OIDC_SCOPES=email,profile.
# OIDC_SCOPES=email,profile,groups
# PKCE on the code flow (recommended; on by default). Disable only for a provider that rejects
# PKCE from confidential clients.
# OIDC_PKCE_ENABLED=true
# LDAP/OIDC group names to map to Administrator and User roles.
# When set, group membership in the IdP token controls role on every login (IdP is source of truth).
# When not set, the first registrant becomes Administrator; all others default to User.
# OIDC_ADMIN_GROUP=diurnal-admins
# OIDC_USER_GROUP=diurnal-users
# RP-initiated logout URL — when set, OIDC users are redirected here after logout
OIDC_LOGOUT_URL=https://auth.example.com/logout
